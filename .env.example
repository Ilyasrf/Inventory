# ── 42 Intra OAuth ──
INTRA_CLIENT_ID=your_42_client_id
INTRA_CLIENT_SECRET=your_42_client_secret
INTRA_REDIRECT_URI=http://localhost:3001/auth/42/callback

# ── JWT ──
JWT_SECRET=change-this-to-a-random-secret-string

# ── Admin Credentials ──
ADMIN_NAME=admin
ADMIN_PASSWORD=admin123

# ── Database ──
# Update this with your actual PostgreSQL connection string from Render
DATABASE_URL=postgresql://user:password@localhost:5432/makina_db
# ── SMTP Email ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Makina Masters <your_email@gmail.com>"

# ── App URLs ──
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001
PORT=3001
NODE_ENV=development
